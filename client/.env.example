# Frontend API target (local development)
VITE_API_URL=http://localhost:5000

# Enable Stream.io chat + audio/video calling UI
VITE_USE_STREAM_CHAT=true

# Google OAuth (get from Google Cloud Console)
VITE_GOOGLE_CLIENT_ID=your_google_client_id

# WebRTC TURN Server (Required for calls on public networks/firewalls)
VITE_TURN_URL=turn:global.turn.twilio.com:3478?transport=udp
VITE_TURN_USERNAME=your_username
VITE_TURN_PASSWORD=your_password

# Sentry Error Tracking (https://sentry.io) - Optional
# VITE_SENTRY_DSN=

# PostHog Analytics (https://posthog.com) - Optional
# VITE_POSTHOG_KEY=