{
  "name": "server",
  "version": "1.0.0",
  "description": "Track AI - Employee Management System Backend",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --detectOpenHandles --forceExit --testTimeout=30000",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:create": "prisma migrate dev",
    "db:migrate:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "db:seed": "node prisma/seed.js",
    "db:standardize-roles": "node scripts/standardizeRoles.js"
  },
  "keywords": [
    "hr",
    "employee-management",
    "saas"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "@sentry/node": "^10.52.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@supabase/supabase-js": "^2.104.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.76.9",
    "compression": "^1.8.1",
    "connect-redis": "^9.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "express-session": "^1.19.0",
    "geoip-lite": "^2.0.2",
    "google-auth-library": "^10.6.2",
    "handlebars": "^4.7.9",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "node-telegram-bot-api": "^0.67.0",
    "nodemailer": "^8.0.7",
    "openai": "^6.17.0",
    "pg": "^8.17.2",
    "prisma": "^7.8.0",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "stream-chat": "^9.43.0",
    "stripe": "^19.3.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "twilio": "^5.4.3",
    "web-push": "^3.6.7",
    "winston": "^3.19.0"
  },
  "overrides": {
    "request": {
      "form-data": "^2.5.4",
      "qs": "^6.14.1",
      "tough-cookie": "^4.1.3",
      "uuid": "^9.0.1"
    },
    "@cypress/request": {
      "uuid": "^9.0.1"
    },
    "node-telegram-bot-api": {
      "request": "^2.88.2"
    }
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "express-winston": "^4.2.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.11",
    "supertest": "^7.2.2",
    "zod": "^3.23.8"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/index.js",
      "!src/db.js",
      "!src/socket/**"
    ],
    "testMatch": [
      "**/tests/**/*.test.js",
      "**/*.test.js"
    ],
    "setupFilesAfterEnv": [
      "./tests/setup.js"
    ]
  }
}
